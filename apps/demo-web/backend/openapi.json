{
  "components": {
    "schemas": {
      "EventAccepted": {
        "properties": {
          "correlation_id": {
            "title": "Correlation Id",
            "type": "string"
          },
          "duplicate": {
            "default": false,
            "title": "Duplicate",
            "type": "boolean"
          },
          "event_id": {
            "title": "Event Id",
            "type": "string"
          },
          "event_timestamp": {
            "format": "date-time",
            "title": "Event Timestamp",
            "type": "string"
          },
          "status": {
            "const": "accepted",
            "default": "accepted",
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "event_id",
          "correlation_id",
          "event_timestamp"
        ],
        "title": "EventAccepted",
        "type": "object"
      },
      "EventRequest": {
        "properties": {
          "action": {
            "enum": [
              "view",
              "cart",
              "purchase"
            ],
            "title": "Action",
            "type": "string"
          },
          "idempotency_key": {
            "anyOf": [
              {
                "maxLength": 200,
                "minLength": 8,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Idempotency Key"
          },
          "impression_id": {
            "anyOf": [
              {
                "maxLength": 160,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Impression Id"
          },
          "product_id": {
            "minimum": 1.0,
            "title": "Product Id",
            "type": "integer"
          },
          "quantity": {
            "default": 1,
            "maximum": 100.0,
            "minimum": 1.0,
            "title": "Quantity",
            "type": "integer"
          },
          "request_id": {
            "anyOf": [
              {
                "maxLength": 160,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Request Id"
          },
          "session_id": {
            "maxLength": 160,
            "minLength": 1,
            "title": "Session Id",
            "type": "string"
          },
          "user_id": {
            "minimum": 1.0,
            "title": "User Id",
            "type": "integer"
          }
        },
        "required": [
          "user_id",
          "product_id",
          "action",
          "session_id"
        ],
        "title": "EventRequest",
        "type": "object"
      },
      "EventStatus": {
        "properties": {
          "event_id": {
            "title": "Event Id",
            "type": "string"
          },
          "feature_service_available": {
            "default": true,
            "title": "Feature Service Available",
            "type": "boolean"
          },
          "status": {
            "enum": [
              "accepted",
              "feature_store_updated"
            ],
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "event_id",
          "status"
        ],
        "title": "EventStatus",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "Product": {
        "properties": {
          "brand_id": {
            "title": "Brand Id",
            "type": "integer"
          },
          "brand_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Brand Name"
          },
          "category_code": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Category Code"
          },
          "category_id": {
            "title": "Category Id",
            "type": "integer"
          },
          "current_price": {
            "title": "Current Price",
            "type": "number"
          },
          "price_bucket": {
            "title": "Price Bucket",
            "type": "integer"
          },
          "product_id": {
            "title": "Product Id",
            "type": "integer"
          },
          "product_name": {
            "title": "Product Name",
            "type": "string"
          }
        },
        "required": [
          "product_id",
          "product_name",
          "category_id",
          "brand_id",
          "current_price",
          "price_bucket"
        ],
        "title": "Product",
        "type": "object"
      },
      "ProductPage": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/Product"
            },
            "title": "Items",
            "type": "array"
          },
          "limit": {
            "title": "Limit",
            "type": "integer"
          },
          "offset": {
            "title": "Offset",
            "type": "integer"
          },
          "total": {
            "title": "Total",
            "type": "integer"
          }
        },
        "required": [
          "items",
          "total",
          "limit",
          "offset"
        ],
        "title": "ProductPage",
        "type": "object"
      },
      "RecommendationItem": {
        "properties": {
