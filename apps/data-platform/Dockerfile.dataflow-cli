ARG RECSYS_BASE_IMAGE=recsys-base-python:local
FROM ${RECSYS_BASE_IMAGE}

WORKDIR /opt/recsys
COPY pyproject.toml uv.lock* /opt/recsys/
ENV PYTHONPATH=/opt/recsys/apps/data-platform/src:/opt/recsys

RUN uv pip install --no-cache \
    pyarrow \
    pyyaml \
    pydantic \
    numpy \
    evidently \
    boto3 \
    s3fs \
    psycopg[binary] \
    redis \
    requests \
    kfp \
    "feast[redis]"

COPY . /opt/recsys

CMD ["bash"]
