pipeline {
  agent any

  options {
    skipDefaultCheckout(false)
    disableConcurrentBuilds()
  }

  parameters {
    string(name: 'TARGET_REVISION', defaultValue: '', description: 'Helm revision to restore. Empty selects the previous revision.')
    string(name: 'COMPONENT_DEPLOY_TIMEOUT', defaultValue: '600s', description: 'Rollback and rollout timeout.')
    string(name: 'GATEWAY_SMOKE_CREDENTIALS_ID', defaultValue: '', description: 'Optional Jenkins username/password credential for authenticated public smoke.')
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Rollback Production') {
      steps {
        script {
          def command = "TARGET_REVISION='${params.TARGET_REVISION}' COMPONENT_DEPLOY_TIMEOUT='${params.COMPONENT_DEPLOY_TIMEOUT}' bash jenkins/scripts/demo_web_rollback.sh"
          if (params.GATEWAY_SMOKE_CREDENTIALS_ID?.trim()) {
            withCredentials([usernamePassword(credentialsId: params.GATEWAY_SMOKE_CREDENTIALS_ID, usernameVariable: 'GATEWAY_SMOKE_USER', passwordVariable: 'GATEWAY_SMOKE_PASSWORD')]) {
              sh command
            }
          } else {
            sh command
          }
        }
      }
    }
  }

  post {
    always {
      archiveArtifacts allowEmptyArchive: true, artifacts: '.demo-web/*'
    }
  }
}
