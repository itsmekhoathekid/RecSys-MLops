{
  "uid": "recsys-data-pipeline",
  "title": "Data Pipeline Observability",
  "tags": ["recsys", "data-platform", "streaming"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "30s",
  "graphTooltip": 1,
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Streaming Events",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "sum(recsys_streaming_event_count) or vector(0)", "legendFormat": "events" }],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "palette-classic" } } },
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Late Events",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "sum(recsys_streaming_late_event_count) or vector(0)", "legendFormat": "late" }],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 10 }] } } },
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Data Quality Pass",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "min(recsys_data_quality_passed) or vector(0)", "legendFormat": "passed" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "decimals": 0, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showThresholdLabels": true, "showThresholdMarkers": true }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Quality Errors",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "sum(recsys_data_quality_error_count) or vector(0)", "legendFormat": "errors" }],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 5 }] } } },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Streaming Windows",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "recsys_streaming_event_count or vector(0)", "legendFormat": "events {{window_start}}" },
        { "expr": "recsys_streaming_late_event_count or vector(0)", "legendFormat": "late {{window_start}}" },
        { "expr": "recsys_streaming_duplicate_event_count or vector(0)", "legendFormat": "duplicates {{window_start}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 35, "stacking": { "mode": "normal", "group": "A" } } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Late Arrival Severity",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "recsys_streaming_max_late_by_seconds or vector(0)", "legendFormat": "max late seconds" },
        { "expr": "recsys_streaming_bursty_window or vector(0)", "legendFormat": "bursty window" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Online Store Sync",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "expr": "recsys_online_store_sync_scanned_rows or vector(0)", "legendFormat": "scanned" },
        { "expr": "recsys_online_store_sync_synced_rows or vector(0)", "legendFormat": "synced" },
        { "expr": "recsys_online_store_sync_skipped_rows or vector(0)", "legendFormat": "skipped" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 8,
      "type": "bargauge",
      "title": "Warehouse Drift Score",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [{ "expr": "recsys_feature_drift_score or vector(0)", "legendFormat": "{{feature}}" }],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 3, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 0.1 }, { "color": "red", "value": 0.2 }] } } },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showUnfilled": true }
    },
    {
      "id": 9,
      "type": "bargauge",
      "title": "Offline Generator Volume",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [
        { "expr": "recsys_data_quality_metric{check_name=\"generator.offline.synthetic_issues\",metric_name=~\"row_count_.*\"} or vector(0)", "legendFormat": "{{metric_name}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "palette-classic" } } },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showUnfilled": true }
    },
    {
      "id": 10,
      "type": "bargauge",
      "title": "Offline Cardinality",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "targets": [
        { "expr": "recsys_data_quality_metric{check_name=\"generator.offline.synthetic_issues\",metric_name=~\"approx_count_distinct_.*\"} or vector(0)", "legendFormat": "{{metric_name}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "palette-classic" } } },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showUnfilled": true }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Offline Data Issues",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 },
      "targets": [
        { "expr": "recsys_data_quality_metric{check_name=\"generator.offline.synthetic_issues\",metric_name=~\"duplicate_rate_before_dedup|duplicate_rate_after_dedup|late_arrival_rate|out_of_order_rate|top_city_ratio|top_event_category_ratio\"} or vector(0)", "legendFormat": "{{metric_name}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 3, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 12,
      "type": "bargauge",
      "title": "Schema Evolution Nulls",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 8 },
      "targets": [
        { "expr": "recsys_data_quality_metric{check_name=\"generator.offline.synthetic_issues\",metric_name=~\"schema_v1_events|schema_v2_events|null_device_type_events|exact_duplicate_rows|conflicting_duplicate_event_ids\"} or vector(0)", "legendFormat": "{{metric_name}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 100 }] } } },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showUnfilled": true }
    }
  ]
}
